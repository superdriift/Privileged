lapseOnSelect expand=\"lg\" bg=\"dark\" variant=\"dark\" style={{ paddingLeft: \"20px\", paddingRight: \"20px\" }}>\n    //       <Container fluid>\n    //         {/* <Navbar.Brand href=\"/\"> Privileged Pieces </Navbar.Brand> */}\n    //         <Navbar.Toggle aria-controls=\"responsive-navbar-nav\" />\n    //         <Navbar.Collapse id=\"responsive-navbar-nav\">\n    //           <Nav className=\"m-auto\">\n    //             <Nav.Link href=\"https://instagram.com/privileged_pieces?igshid=MDM4ZDc5MmU=\" target=\"_blank\" rel=\"noopener noreferrer\"> Instagram Link </Nav.Link>\n    //             <Nav.Link href=\"/#otherlink\"> Facebook Link </Nav.Link>\n    //           </Nav>\n    //         </Navbar.Collapse>\n    //       </Container>\n    //     </Navbar>\n    //   )\n    // } else {\n      return (\n        <div style={{ backgroundColor:\"black\" }}>\n          <Navbar collapseOnSelect expand=\"lg\" bg=\"\" variant=\"dark\" style={{ paddingLeft: \"20px\", paddingRight: \"20px\" }}>\n            <Container fluid>\n              {/* <Navbar.Brand href=\"/\"> Privileged Pieces </Navbar.Brand> */}\n              <Navbar.Toggle aria-controls=\"responsive-navbar-nav\" />\n              <Navbar.Collapse id=\"responsive-navbar-nav\">\n                <Nav className=\"m-auto\">\n                  <Nav.Link href=\"https://instagram.com/privileged_pieces\" target=\"_blank\" rel=\"noopener noreferrer\">\n                    <FaInstagram style={{ height:\"36pt\", width:\"36pt\"}} />\n                  </Nav.Link>\n                </Nav>\n              </Navbar.Collapse>\n            </Container>\n          </Navbar>\n        </div>\n      )\n    }\n  // }\n\n  // return (\n  //   Footer()\n  // )\n\nexport default Footer;\n","/Users/julian/Desktop/webappPrivilegedPieces/Privileged/client/src/components/Catbar/index.js",["312","313","314","315","316","317","318","319","320"],"import React, { useEffect } from 'react';\nimport ProductItem from '../ProductItem';\nimport { useStoreContext } from '../../utils/GlobalState';\nimport { UPDATE_PRODUCTS } from '../../utils/actions';\nimport { useQuery } from '@apollo/client';\nimport { QUERY_PRODUCTS } from '../../utils/queries';\nimport { idbPromise } from '../../utils/helpers';\nimport spinner from '../../assets/spinner.gif';\nimport Button from 'react-bootstrap/Button';\nimport Card from 'react-bootstrap/Card';\nimport Nav from 'react-bootstrap/Nav';\nimport NavDropdown from 'react-bootstrap/NavDropdown';\nimport Navbar from 'react-bootstrap/Navbar';\nimport Container from 'react-bootstrap/Container';\nimport Form from 'react-bootstrap/Form';\nimport {\n  UPDATE_CATEGORIES,\n  UPDATE_CURRENT_CATEGORY,\n} from '../../utils/actions';\nimport { QUERY_CATEGORIES } from '../../utils/queries';\n\n\n\n\nconst Catbar = () => {\n  const [state, dispatch] = useStoreContext();\n\n  const { categories, currentCategory } = state;\n\n  const { loading, data: categoryData } = useQuery(QUERY_CATEGORIES);\n\n  useEffect(() => {\n    if (categoryData) {\n      dispatch({\n        type: UPDATE_CATEGORIES,\n        categories: categoryData.categories,\n      });\n      categoryData.categories.forEach((category) => {\n        idbPromise('categories', 'put', category);\n      });\n    } else if (!loading) {\n      idbPromise('categories', 'get').then((categories) => {\n        dispatch({\n          type: UPDATE_CATEGORIES,\n          categories: categories,\n        });\n      });\n    }\n  }, [categoryData, loading, dispatch]);\n\n  function filterProducts() {\n    if (!currentCategory) {\n      return state.products;\n    }\n\n    return state.products.filter(\n      (product) => product.category._id === currentCategory\n    );\n  }\n\n  const handleClick = (id) => {\n    dispatch({\n      type: UPDATE_CURRENT_CATEGORY,\n      currentCategory: id,\n    });\n  };\n\n  return ( \n    <Navbar className=\"bars\" sticky='top' bg='' expand=\"lg\" id='navbar' style={{ paddingLeft: \"10px\", paddingRight: \"10px\" }}>\n      <Container fluid >\n        {/* <Navbar.Brand href=\"#navbar\"> All Pieces </Navbar.Brand> */}\n        <Navbar.Toggle aria-controls=\"navbarScroll\" />\n        <Navbar.Collapse id=\"navbarScroll\">\n          <Nav\n            className=\"me-auto my-2 my-lg-0\"\n            style={{ maxHeight: '100px' }}\n            navbarScroll\n          >\n            <Nav.Link onClick={() => { handleClick() }} href='#navbar'> All Pieces </Nav.Link>\n            {categories.map((item) => (<Nav.Link key={item._id} onClick={() => { handleClick(item._id) }}> {item.name} </Nav.Link>\n            ))}\n          </Nav>\n          {/* <Form className=\"d-flex\">\n            <Form.Control\n              type=\"search\"\n              placeholder=\"Search\"\n              className=\"me-2\"\n              aria-label=\"Search\"\n              input=\"searchInput\"\n              onChange={ filterProducts }\n            />\n            <Button variant=\"outline-secondary\">Search</Button>\n          </Form> */}\n        </Navbar.Collapse>\n      </Container>\n      <br />\n    </Navbar>\n\n  )\n}\n\nexport default Catbar;","/Users/julian/Desktop/webappPrivilegedPieces/Privileged/client/src/pages/Wishlist.js",["321"],"import React, { useState } from 'react';\n// import { useMutation } from '@apollo/client';\n// import { Link } from 'react-router-dom';\n// import { LOGIN } from '../utils/mutations';\n// import Auth from '../utils/auth';\n// import Button from 'react-bootstrap/Button';\n// import Container from 'react-bootstrap/Container';\n\n// import Auth from \"../../utils/auth\";\n// import auth from \"../../utils/auth\";\n\n\n\n\n\nimport Wshlst from \"../components/WshLst\";\n\n\n\nconst Wishlist = () => {\n\n        return (\n            <>\n            <Wshlst/>\n            </>\n        )\n    }\n\nexport default Wishlist;","/Users/julian/Desktop/webappPrivilegedPieces/Privileged/client/src/pages/About.js",[],"/Users/julian/Desktop/webappPrivilegedPieces/Privileged/client/src/components/AbtStatement/index.js",["322","323","324"],"import React from \"react\";\nimport Container from 'react-bootstrap/Container';\nimport Row from 'react-bootstrap/Row';\nimport Col from 'react-bootstrap/Col';\nimport Button from 'react-bootstrap/Button';\n\n\nconst AbtStatement = () => {\n    return (\n        <Container fluid>\n            <h4 style={{ display: \"flex\", justifyContent: \"center\", fontSize: \"18pt\", fontStyle: \"italic\", fontFamily: \"Proxima Nova\" }}> Jade is a precious gem that has been around for over 9,000 years and has always been a symbol of status, spirituality, purity and health. All our Jade pieces are sourced from south east Asia and are hand carved. Each piece has its own symbolism and meaning. Which Privileged Piece are you drawn to? </h4>\n        </Container>\n    )\n}\n\nexport default AbtStatement;","/Users/julian/Desktop/webappPrivilegedPieces/Privileged/client/src/components/WshLst/index.js",["325","326"],"import React, { useState } from 'react';\nimport Auth from \"../../utils/auth\";\nimport auth from \"../../utils/auth\";\n\nconst Wshlst = () => {\n    if (Auth.loggedIn()) {\n        return (\n            <>\n                <h1 style={{ textAlign: \"center\" }}> Username's Wishlist</h1>\n            </>\n        )\n    }\n    else {\n        return(\n        <>\n                <h1> Log in to see your wishlist! </h1>\n        </>\n        )\n    }\n}\n\n\nexport default Wshlst","/Users/julian/Desktop/webappPrivilegedPieces/Privileged/client/src/pages/Profile.js",["327"],"import { React, useState } from \"react\";\nimport Profilo from '../components/Profilo'\n\n\n\nconst Profile = () => {\n    return(\n        <>\n        <h1> Render from Profile.js </h1>\n        <Profilo/>\n        </>\n    )\n}\n\nexport default Profile;","/Users/julian/Desktop/webappPrivilegedPieces/Privileged/client/src/components/Profilo/index.js",[],"/Users/julian/Desktop/webappPrivilegedPieces/Privileged/client/src/pages/Contact.js",[],